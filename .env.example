# Backend Server (local development)
PORT=5001
NODE_ENV=development

# API Keys (Replace with your actual keys)
# Option A - Anthropic direct: https://console.anthropic.com/ (key starts with sk-ant-)
# Option B - OpenRouter: https://openrouter.ai/ (key starts with sk-or-)
ANTHROPIC_API_KEY=your-api-key-here

# Vercel production: add ANTHROPIC_API_KEY in Vercel → Project → Settings → Environment Variables
# Do NOT commit real keys to Git.
